[
  {
    "name": "query_manual",
    "description": "Consulta el manual técnico del equipo activo. Devuelve respuesta con cita.",
    "parameters": {
      "type": "object",
      "properties": {
        "question": { "type": "string", "description": "Pregunta técnica del técnico" },
        "asset_id": {
          "type": "string",
          "description": "Opcional. Usa el asset_id del contexto de sesión; si falta, el backend lo infiere de la OT activa."
        }
      },
      "required": ["question"]
    },
    "webhook": {
      "method": "POST",
      "url_template": "${API_BASE_URL}/v1/elevenlabs/tools/query_manual",
      "headers": {
        "X-Superion-Tool-Auth": "${ELEVENLABS_WEBHOOK_SECRET}"
      },
      "query_parameters": {
        "properties": {
          "session_id": { "type": "string", "dynamic_variable": "session_id" },
          "tool_auth": { "type": "string", "constant_value": "${ELEVENLABS_WEBHOOK_SECRET}" }
        },
        "required": ["session_id", "tool_auth"]
      },
      "response_timeout_secs": 25
    }
  },
  {
    "name": "mark_step_complete",
    "description": "Marca el paso actual como completado y avanza si procede.",
    "parameters": {
      "type": "object",
      "properties": {
        "step_index": { "type": "integer", "description": "Índice del paso" }
      },
      "required": ["step_index"]
    },
    "webhook": {
      "method": "POST",
      "url_template": "${API_BASE_URL}/v1/elevenlabs/tools/mark_step_complete",
      "headers": {
        "X-Superion-Tool-Auth": "${ELEVENLABS_WEBHOOK_SECRET}"
      },
      "query_parameters": {
        "properties": {
          "session_id": { "type": "string", "dynamic_variable": "session_id" },
          "tool_auth": { "type": "string", "constant_value": "${ELEVENLABS_WEBHOOK_SECRET}" }
        },
        "required": ["session_id", "tool_auth"]
      },
      "response_timeout_secs": 25
    }
  },
  {
    "name": "get_current_step",
    "description": "Devuelve el paso actual de la sesión.",
    "parameters": {
      "type": "object",
      "properties": {}
    },
    "webhook": {
      "method": "POST",
      "url_template": "${API_BASE_URL}/v1/elevenlabs/tools/get_current_step",
      "headers": {
        "X-Superion-Tool-Auth": "${ELEVENLABS_WEBHOOK_SECRET}"
      },
      "query_parameters": {
        "properties": {
          "session_id": { "type": "string", "dynamic_variable": "session_id" },
          "tool_auth": { "type": "string", "constant_value": "${ELEVENLABS_WEBHOOK_SECRET}" }
        },
        "required": ["session_id", "tool_auth"]
      },
      "response_timeout_secs": 20
    }
  }
]
