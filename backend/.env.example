# SUPERION Backend — variables de entorno
# Copiar a `.env` para desarrollo local: cp .env.example .env

# Entorno de aplicación
APP_ENV=dev
LOG_LEVEL=INFO
APP_VERSION=0.1.0

# Reloj: real (SystemClock) | memory (InMemoryClock determinista)
CLOCK_MODE=real

# Auth — JWT HS256 in-memory
AUTH=memory
JWT_SECRET=change-me-32-bytes-minimum-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=2592000
PASSWORD_BCRYPT_ROUNDS=10

# Adapters — defaults memory/mock (sin servicios externos)
PERSISTENCE=memory
LLM=mock
VOICE=mock
VECTOR_STORE=memory
STORAGE=memory
PDF=mock
REPORT_BUILDER=memory

# WebSocket y event bus
WS_HEARTBEAT_INTERVAL=30
WS_PONG_TIMEOUT=60
WS_REPLAY_ON_CONNECT=true
EVENTBUS=memory

# Fotos — BE-04
API_BASE_URL=http://localhost:8000
PHOTO_VALIDATOR=mock
PHOTO_MAX_SIZE_MB=10
PHOTO_MAX_RETRIES=3
# Manuales / RAG — BE-05
EMBEDDING=mock
EMBEDDING_DIM=384
RERANKER=mock
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RAG_TOP_K=8
RAG_TOP_N=3
RAG_ABSTAIN_THRESHOLD=0.3
MANUAL_MAX_SIZE_MB=50
MANUAL_INDEX_ESTIMATED_SECONDS=90

# Voz / ElevenLabs — BE-06 + BE-09
INTENT_CLASSIFIER=mock
LANGGRAPH=mock
ELEVENLABS_WEBHOOK_SECRET=change-me
ELEVENLABS_SIGNATURE_WINDOW_SECONDS=300
ELEVENLABS_PROVISIONER=memory
ELEVENLABS_AGENT_MANIFEST=elevenlabs/agent.yaml
ELEVENLABS_STATE_FILE=elevenlabs/state.json
ELEVENLABS_AGENT_ID=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_CONNECT_MODE=signed_url
DEPLOY_ENV=dev

# Observabilidad y hardening — BE-08
METRICS=memory
RATE_LIMIT_PER_MIN=60
RATE_LIMIT_ENABLED=true
AUDIT_LOG=memory
SECURITY_HEADERS=true

# Dependencias externas (ready check cuando mode != memory/mock)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
OPENROUTER_API_KEY=
ELEVENLABS_API_KEY=
LANGGRAPH_URL=
