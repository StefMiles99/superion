# SUPERION mobile — variables de entorno (copiar a apps/mobile/.env)

# Modos de adaptadores: mock corre TODO sin backend.
VITE_API_MODE=mock          # mock | http
VITE_WS_MODE=mock           # mock | real
VITE_VOICE_MODE=mock        # mock | elevenlabs

# URLs del backend (solo se usan cuando el modo es http/real)
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000

# Localización
VITE_DEFAULT_LOCALE=es-ES
