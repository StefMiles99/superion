{
  "name": "superion-frontend",
  "private": true,
  "version": "0.1.0",
  "description": "SUPERION frontend — monorepo (mobile voice-first)",
  "scripts": {
    "dev": "pnpm --filter @superion/mobile dev",
    "build": "pnpm --filter @superion/mobile build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@10.11.0",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
