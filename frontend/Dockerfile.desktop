# SUPERION desktop — Cloud Run (SPA estática)
FROM node:22-alpine AS builder

RUN corepack enable

WORKDIR /app

COPY frontend/package.json frontend/pnpm-lock.yaml frontend/pnpm-workspace.yaml frontend/tsconfig.base.json ./
COPY frontend/apps/mobile/package.json apps/mobile/
COPY frontend/apps/desktop/package.json apps/desktop/
COPY frontend/packages packages/

RUN pnpm install --frozen-lockfile

COPY frontend/apps/desktop apps/desktop

ARG VITE_API_BASE_URL=https://example.com
ARG VITE_WS_BASE_URL=wss://example.com
ARG VITE_API_MODE=http
ARG VITE_WS_MODE=real
ARG VITE_DEFAULT_LOCALE=es-ES

ENV VITE_API_BASE_URL=$VITE_API_BASE_URL \
    VITE_WS_BASE_URL=$VITE_WS_BASE_URL \
    VITE_API_MODE=$VITE_API_MODE \
    VITE_WS_MODE=$VITE_WS_MODE \
    VITE_DEFAULT_LOCALE=$VITE_DEFAULT_LOCALE

RUN pnpm --filter @superion/desktop build

FROM nginx:1.27-alpine AS runtime

COPY frontend/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/apps/desktop/dist /usr/share/nginx/html

EXPOSE 8080

CMD ["nginx", "-g", "daemon off;"]
